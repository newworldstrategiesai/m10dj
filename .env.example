# Database (Supabase Postgres)
POSTGRES_URL="postgres://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x"
POSTGRES_USER="postgres"
POSTGRES_HOST="db.[PROJECT_REF].supabase.co"
POSTGRES_PASSWORD="your_postgres_password_here"
POSTGRES_DATABASE="postgres"
POSTGRES_PRISMA_URL="postgres://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase (get these from your project Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
SUPABASE_JWT_SECRET="your_jwt_secret_here"

# Cloudflare Turnstile (optional – for signup/contact spam protection; https://dash.cloudflare.com/?to=/:account/turnstile)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Resend webhooks (each endpoint has its own signing secret in Resend Dashboard > Webhooks)
# Existing: email-received, email-opened (or app route). Keep RESEND_WEBHOOK_SECRET for whichever you use.
# New unified outbound-events endpoint (POST /api/webhooks/resend): use the secret shown for that URL.
# RESEND_WEBHOOK_SECRET=whsec_xxx
# RESEND_WEBHOOK_SECRET_UNIFIED=whsec_yyy
